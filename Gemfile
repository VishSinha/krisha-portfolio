source "https://rubygems.org"

# GitHub Pages builds this site, so we use the github-pages gem to match its
# environment exactly. It bundles Jekyll plus the plugins below.
gem "github-pages", group: :jekyll_plugins

# Plugins declared in _config.yml (already included by github-pages, listed
# here for clarity).
group :jekyll_plugins do
  gem "jekyll-sitemap"
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
end

# Windows/macOS compatibility helpers (harmless elsewhere).
gem "webrick", "~> 1.8"
